# JEDIDIA Marketplace Backend Configuration

# ===== SERVER =====
NODE_ENV=development
PORT=5000

# ===== DATABASE (PostgreSQL) =====
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=password
PGDATABASE=jedidia_marketplace

# ===== JWT TOKENS =====
JWT_ACCESS_SECRET=your-secret-key-here-minimum-32-characters-required
JWT_REFRESH_SECRET=your-refresh-secret-key-here-minimum-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===== FRONTEND INTEGRATION =====
FRONTEND_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:5000

# ===== AI SERVICES =====
# Anthropic Claude for AI assistants (Jarvis, Joseph, Petiti)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# ===== GOOGLE SERVICES =====
# For Google OAuth sign-in
GOOGLE_CLIENT_ID=
# For Google Custom Search (product image sourcing)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# ===== FILE UPLOADS (Cloudinary) =====
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===== PAYMENT PROVIDERS =====
# Stripe
STRIPE_SECRET_KEY=

# Flutterwave
FLUTTERWAVE_SECRET_KEY=

# DPO
DPO_COMPANY_TOKEN=

# Coinbase Commerce (Crypto)
COINBASE_COMMERCE_API_KEY=

# ===== SMS & COMMUNICATIONS (Twilio) =====
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ===== MARKETPLACE SETTINGS =====
# Seller/Delivery upgrade verification fee
UPGRADE_VERIFICATION_FEE=1000
UPGRADE_FEE_CURRENCY=UGX

# ===== ADMIN EMAIL (Optional) =====
ADMIN_EMAIL=admin@jedidia.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
